#define LL long long
#define MOD 1000000007LL

LL F[1005];
LL C[1005][1005];
LL A[1005][1005];

LL f(LL N, LL M, LL K){
    if(M == K)return F[N-M];
    if(K == 0){
        if(A[N][M])return A[N][M];
        LL ans = F[N];
        for(int i=1;i<=M;i++){
            ans -= f(N, M, i);
            if(ans<0)ans+=MOD;
        }
        return A[N][M] = ans;
    }
    return (C[M][K] * f(N-K, M-K, 0))%MOD;
}

