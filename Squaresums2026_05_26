#include <iostream>
#include <vector>
//permutations problem

using namespace std;

//let's create the factorials 
const int Maxn = 1000;
const long long MOD = 1000000007;


long long fact[Maxn + 1];

void build_factorials()
{
    fact[0] = 1;
    for(int i = 1; i <= Maxn; i++)
    {
        fact[i] = (fact[i - 1] * i )% MOD;

    }
}

//let's create the combination function
long long combination[Maxn + 1][Maxn + 1];

void build_combination()
{
    combination[0][0] = 1;

    for (int n = 1; n <= Maxn; n++)
    {
        combination[n][0] = 1;
        combination[n][n] = 1;

        for (int r = 1; r < n; r++)
        {
            combination[n][r] = (combination[n -1][r] + combination[n -1][r -1]) % MOD;

        }

    }

}

long long memo[Maxn + 1][Maxn + 1];
bool calculated[Maxn + 1][Maxn + 1];

long long solve(int N, int M, int K)
{
    //if all first M positions are fixed 
    if (K == M)
    {
        return fact[N - M];
    }

    //if none of the first postions of M may be fixed 
    if (K == 0)
    {
        if (calculated[N][M])
        {
            return memo[N][M];
        }

        long long answer = fact[N];

        for(int fixed = 1; fixed <= M; fixed++)
        {
            answer -= solve(N, M, fixed);

            if (answer < 0)
            {
                answer += MOD;
            }
        }

        calculated[N][M] = true;
        memo[N][M] = answer;

        return answer; 

    }

    long long choosepositions = combination[M][K];

    long long arrangeRemaining = solve(N - K, M - K , 0);

    return (choosepositions * arrangeRemaining) % MOD;

}

int main()
{
    build_factorials();
    build_combination();

    int T ;
    cin >> T;

    for (int cas = 1; cas <= T; cas++)
    {
        int N, M, K;
        cin >> N >> M >> K;

        cout << "Case " << cas << ": " << solve(N, M, K) << endl;
    }
    return 0;
}

