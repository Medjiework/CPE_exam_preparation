#include <iostream>
#include <cassert>
#include <algorithm>

using namespace std;

//NB: the whole rectangle is 100 * 100
//check if the inputs are in between 0 and 100
void check (int n)
{
    assert(n >= 0);
    assert(n <= 100);
}

    int main()
    {
    //let's take inputs here (using arrays form)
        int T;
        cin >> T; 
        int cas = 1;
        while (T--)
            {
            int x[4], y[4];
            for (int i = 0; i < 4; i++)
            {
                cin >> x[i] >> y[i];
                check(x[i]);
                check(y[i]);
            }
            
            
     int a0 = 0, a1 = 0, a2 = 0; //they will store my solution to this exercise(a0 for strong, a1 for weak and a3 as unsecured area)

    /*find area of the two rectangles and the overlap area
    first, find the edges of overlapping part */

        int x0 = max(x[0], x[2]);
        int x1 = min(x[1], x[3]);
        

        int y0 = max(y[0], y[2]);
        int y1 = min(y[1], y[3]);
        //the assert checks if it is a true rectangle or not .
        assert(x[0] < x[1]);
        assert(y[0] < y[1]);
        assert(x[2] < x[3]);
        assert(y[2] < y[3]);

        if (x0 < x1 && y0 < y1)
        
        a0 = (x1 - x0) * (y1 - y0);

        //the area of the rectangles

        a1 = abs((x[1] - x[0]) * ((y[1] - y[0]))) + abs((x[3] - x[2]) * ((y[3] - y[2]))) - (a0 * 2);

        //non-secured area
        a2 = (100 * 100) - a1 - a0;

    printf("Night %d: %d %d %d\n", cas, a0, a1, a2);
    cas++;
    }
            
    return 0;

    }

