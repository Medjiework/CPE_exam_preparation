#include <iostream>
#include <algorithm>

using namespace std;

int main()
{
    int field = 1;
    int r, c;
    while (cin >> r >> c)
    {
        if (r == 0 && c == 0)
        {
            break;
        }
    
    //read the grid now 
    char grid[100][100];
    for (int i = 0; i < r; i++)
    {
        for (int j = 0; j < c; j++)
        {
            cin >> grid[i][j];
    
        }
    }
//store the movement inside arrays (8 directions to check)

   //direction row  
   int dr[8] = {-1, -1, -1, 0, 0, 1, 1, 1};
   //direction column
   int dc[8] = {-1, 0, 1, -1, 1, -1, 0, 1};

    if (field > 1) 
    {
        cout << endl;
    }
    //to print the first line of the output and the number of field 
    cout << "Field #" << field << ":"<< endl;

    //check all directions and create the result grid 

    for (int i = 0; i < r; i++)
    {
        for (int j = 0; j < c; j++)
        {
            if (grid[i][j] == '*')
            {
                cout << '*';

            }

            else if (grid[i][j] == '.')
            {
                int count = 0;
                //check 8 positions around the '.'
                for (int k = 0; k < 8; k++)
                {
                    int ni = i + dr[k];
                    int nj = j + dc[k];
                

                //check if the new position is valid end of the grid 

                if (ni >= 0 && ni < r && nj >= 0 && nj < c)
                {
                    if (grid[ni][nj] == '*')
                    {
                        count++;
                    }
                }
                
                }
                cout << count;

            }
           
        }
        cout << endl;

        
    }

    field++;
    }

    return 0;
}

