#include <string>
#include <iostream>
#include <cassert>

using namespace std;

int main()
{
    int T;
    cin >> T;
    int cas = 1;
    assert(T <= 100);

    while (T--)
    {
        string s;
        cin >> s;
        assert(s.size() < 100000);

    char m[100] = {}; //use to store each value of the cell
    int p = 0;

        for (auto&c: s)
        {
            if (c == '>')
            {
                p = (p + 1 + 100) % 100;
            }
            else if (c == '<')
            {
                p = (p - 1 + 100) % 100;
            }
            else if (c == '+')
            {
                m[p]++;
            }
            else if (c == '-')
            {
                m[p]--;
            }
        }
            printf("Case %d: ", cas++);

            for (auto&c : m)
            {
                printf(" %02X",int(c) & 0xff);

            }
        
        cout << endl;
    }



    return 0;
}









